    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState } from \"react\";\nimport { Plus, Minus, HelpCircle, Check } from \"lucide-react\";\n\nexport default function FaqSection() {\n  const [openIndex, setOpenIndex] = useState<number | null>(null);\n\n  const faqs = [\n    {\n      question: \"\302\277C\303\263mo se realiza el pago?\",\n      answer: \"El pago se realiza por adelantado de manera 100% segura mediante Yape, Plin o transferencia bancaria (BCP / BBVA / Interbank). Recibir\303\241s las instrucciones de pago detalladas autom\303\241ticamente en tu correo electr\303\263nico con las cuentas correspondientes una vez que registres tu ticket arriba.\"\n    },\n    {\n      question: \"\302\277Qu\303\251 pasa si no puedo asistir a la sesi\303\263n agendada?\",\n      answer: \"\302\241No te preocupes! Entendemos que surgen imprevistos universitarios o escolares. Puedes reprogramar tu sesi\303\263n de manera totalmente gratuita hasta con 24 horas de anticipaci\303\263n a trav\303\251s del enlace de auto-servicio que te llegar\303\241 al correo electr\303\263nico.\"\n    },\n    {\n      question: \"\302\277Haces mentor\303\255a grupal para proyectos grandes?\",\n      answer: \"S\303\255, por supuesto. Si est\303\241s armando un proyecto grupal de fin de ciclo o una tesis t\303\251cnica con tus compa\303\261eros de clase y necesitan asesor\303\255a conjunta, escr\303\255beme directamente por Discord. Tarifas especiales para grupos de hasta 5 integrantes.\"\n    },\n    {\n      question: \"\302\277La Inteligencia Artificial remplazar\303\241 a los Ingenieros de Software?\",\n      answer: \"Rpta de Kuni: \302\241Para nada, crack! Al rev\303\251s, la IA es tu supercopiloto. Multiplica por 10 tu rapidez de desarrollo, pero a\303\272n necesita un cerebro t\303\251cnico humano capaz de estructurar las bases l\303\263gicas, depurar errores complejos de arquitectura, y tomar decisiones de negocio realistas. En las sesiones te ense\303\261o a usarla a tu favor.\"\n    }\n  ];\n\n  const handleToggle = (index: number) => {\n    setOpenIndex(openIndex === index ? null : index);\n  };\n\n  return (\n    <section id=\"faq\" className=\"bg-[#fcf9f8] py-16 px-4 sm:px-6 lg:px-8 border-b-2 border-black\">\n      <div className=\"max-w-4xl mx-auto space-y-10\">\n        \n        {/* Section Header */}\n        <div className=\"text-center space-y-3\">\n          <HelpCircle className=\"w-8 h-8 text-[#0054d4] mx-auto\" />\n          <h2 className=\"text-3xl sm:text-4xl lg:text-5xl font-black font-sans tracking-tight text-gray-900 leading-none\">\n            Preguntas Frecuentes\n          </h2>\n          <p className=\"max-w-xl mx-auto text-sm sm:text-base text-gray-600 font-sans\">\n            Todo lo que necesitas saber antes de iniciar nuestra primera llamada de orientaci\303\263n tech.\n          </p>\n        </div>\n\n        {/* Accordions */}\n        <div className=\"space-y-4\">\n          {faqs.map((faq, idx) => {\n            const isOpen = openIndex === idx;\n            return (\n              <div\n                key={idx}\n                className=\"bg-white border-2 border-black rounded-2xl overflow-hidden shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] hover:shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:-translate-y-0.5 transition-all text-left\"\n              >\n                {/* Trigger Row */}\n                <button\n                  type=\"button\"\n                  onClick={() => handleToggle(idx)}\n                  className=\"w-full p-5 sm:p-6 flex justify-between items-center text-left font-sans font-black text-sm sm:text-base text-gray-900 cursor-pointer\"\n                  id={`faq-accordion-trigger-${idx}`}\n                >\n                  <span className=\"pr-4\">{faq.question}</span>\n                  <div className=\"p-1 border border-black bg-[#fcf9f8] rounded-lg\">\n                    {isOpen ? <Minus className=\"w-4 h-4 text-[#0054d4]\" /> : <Plus className=\"w-4 h-4 text-gray-700\" />}\n                  </div>\n                </button>\n\n                {/* Answer Content */}\n                {isOpen && (\n                  <div className=\"px-5 pb-5 sm:px-6 sm:pb-6 font-sans text-xs sm:text-sm text-gray-600 leading-relaxed border-t border-dashed border-gray-200 bg-gray-50 pt-4 animate-fade-in\">\n                    {faq.answer}\n                  </div>\n                )}\n              </div>\n            );\n          })}\n        </div>\n\n      </div>\n    </section>\n  );\n}\n"
    }
