# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ── Supabase ─────────────────────────────────────────────────────────────────
# Local dev: run `npx supabase status` and copy API_URL + SERVICE_ROLE_KEY.
# Server-side only. Never expose the service-role key to the browser.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Mercado Pago (Yape) ──────────────────────────────────────────────────────
# PAYMENT_MODE: "mock" (simulated charges, no external calls) | "live" (real Mercado Pago).
PAYMENT_MODE=mock
MP_PUBLIC_KEY=TEST-xxx
MP_ACCESS_TOKEN=TEST-xxx
# Webhook signing secret, from the Mercado Pago dashboard (Your integrations → Webhooks).
MP_WEBHOOK_SECRET=

# ── Calendly ─────────────────────────────────────────────────────────────────
# Public scheduling page (fallback when no API token is set).
CALENDLY_URL=https://calendly.com/your-user/30min
# Personal Access Token + event type URI enable TRUE single-use links:
CALENDLY_API_TOKEN=
CALENDLY_EVENT_TYPE_URI=

# ── Session price (in cents of PEN: S/30.00) ─────────────────────────────────
SESSION_PRICE_CENTS=3000

# ── Booking sync ──────────────────────────────────────────────────────────────
# How often to poll Calendly to flip bookings link_issued → scheduled.
# Default 300000 (5 min); set 0 to disable the periodic sync.
BOOKING_SYNC_INTERVAL_MS=300000

# ── Upstash Redis (rate limiting) ───────────────────────────────────────────
# REST URL + token from the Upstash console (Database → REST API).
# Optional: POST /api/checkout skips rate limiting entirely if unset.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── reCAPTCHA v3 (bot protection on checkout) ───────────────────────────────
# From the reCAPTCHA admin console (google.com/recaptcha/admin), v3 key type.
# VITE_ prefix required: this key ships in the browser bundle by design.
VITE_RECAPTCHA_SITE_KEY=
# Server-side only. Optional: POST /api/checkout skips verification if unset.
RECAPTCHA_SECRET_KEY=
